# ============================================================
#  SNNUBBAF 配置文件
#  复制本文件为 .env 并填入实际配置
# ============================================================

# ── NotebookLM ────────────────────────────────────────────────
# 必填。你的 NotebookLM 笔记本 ID
# 运行 npx notebooklm list --transport auto 可查看笔记本列表
NOTEBOOKLM_NOTEBOOK_ID=your-notebook-id-here

# ── 服务器 ───────────────────────────────────────────────────
# PORT=38765
