# ============================================================
#  SNNUBBAF 配置文件
#  复制本文件为 .env 并填入实际的 API Key
#  API Key 为必填项，其余项删除或注释后将使用源码默认值
# ============================================================

# 概念提取（调用 LLM，耗时长，默认关闭）
# 设为 true 后可用 --skip-concepts 强制跳过，用 --with-concepts 强制开启
EXTRACT_CONCEPTS=false

# ── 智谱 Embedding ───────────────────────────────────────────
EMBEDDING_API_KEY=your-embedding-api-key-here
# EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/embeddings
# EMBEDDING_MODEL=embedding-3

# ── LLM（build-kb.mjs 概念提取）────────────────────────────
BUILD_LLM_API_KEY=your-build-llm-api-key-here
# BUILD_LLM_BASE_URL=https://mydamoxing.cn/v1/chat/completions
# BUILD_LLM_MODEL=glm-5

# ── LLM 主模型（answer-server.mjs）─────────────────────────
LLM_PRIMARY_API_KEY=your-primary-llm-api-key-here
LLM_PRIMARY_BASE_URL=https://mydamoxing.cn/v1/responses
LLM_PRIMARY_MODEL=gpt-5.1

# ── LLM 备用模型（answer-server.mjs）───────────────────────
LLM_FALLBACK_API_KEY=your-fallback-llm-api-key-here
# LLM_FALLBACK_BASE_URL=https://mydamoxing.cn/v1/chat/completions
LLM_FALLBACK_MODEL=glm-5

# ── 服务器 ───────────────────────────────────────────────────
# PORT=38765

# ── 路径（相对于项目根目录）────────────────────────────────
# SOURCE_DIR=source
# PROCESSED_DIR=source-processed
# DB_DIR=vector-db

# ── 分块配置 ─────────────────────────────────────────────────
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=300

# ── 向量检索 ─────────────────────────────────────────────────
# TOP_K=5
